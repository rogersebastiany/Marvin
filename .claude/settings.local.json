{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__mcp-marvin__.*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre_mcp_tool.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/edit_gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__mcp-marvin__.*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post_mcp_tool.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session_start.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(docker *)",
      "Bash(uv *)",
      "Bash(ls *)",
      "Bash(ps *)",
      "Bash(mkdir *)",
      "Bash(chmod *)",
      "Bash(timeout *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(awk *)",
      "Bash(python3 *)",
      "Bash(gh *)",
      "mcp__mcp-marvin__*"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "mcp-marvin"
  ]
}
