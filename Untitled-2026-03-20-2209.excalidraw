      "seed": 830073778,
      "version": 722,
      "versionNonce": 1472917490,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773788108837,
      "link": null,
      "locked": false,
      "text": "SE VC TEM UM AGENTE BEM DEFINIDO, COM AS TOOLS CERTAS, SERVIDAS VIA MCP, \nE TIVER TOOL PRA TODO O PROCESSO, LITERALMENTE TUDO, VC TEM A TOOL DA \nDOC DA VERSAO DA AWS SQS Q VC USA DE MENSAGERIA, A TOOL COM A DOC DO POSTGRES, \nSEI LA, E TODA CONEXÃO EXTERNA TBM FOR VIA MCP, VC MEIO QUE CRIA UM CONTEXTO \nONTOLOGICO POR DESIGN, ELE ESTÁ EM TODO O CONTEXTO DA APLICAÇÃO, TEM O HISTORICO COMPLETO DE TODA A HISTORIA SEMPRE.",
      "fontSize": 103.18749999999987,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SE VC TEM UM AGENTE BEM DEFINIDO, COM AS TOOLS CERTAS, SERVIDAS VIA MCP, \nE TIVER TOOL PRA TODO O PROCESSO, LITERALMENTE TUDO, VC TEM A TOOL DA \nDOC DA VERSAO DA AWS SQS Q VC USA DE MENSAGERIA, A TOOL COM A DOC DO POSTGRES, \nSEI LA, E TODA CONEXÃO EXTERNA TBM FOR VIA MCP, VC MEIO QUE CRIA UM CONTEXTO \nONTOLOGICO POR DESIGN, ELE ESTÁ EM TODO O CONTEXTO DA APLICAÇÃO, TEM O HISTORICO COMPLETO DE TODA A HISTORIA SEMPRE.",
      "autoResize": true,
      "lineHeight": 1.25
    },
