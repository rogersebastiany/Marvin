    {
      "id": "eX37OIiTdVN7TE-4z_gR6",
      "type": "text",
      "x": 7706.210357585607,
      "y": -1151.7102772418057,
      "width": 7670.8212890625,
      "height": 644.9218749999991,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
